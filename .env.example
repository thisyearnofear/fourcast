# ── Bright Data (required for web intelligence features) ──────────────
# Sign up at https://brightdata.com and create these zones:
#   1. SERP API zone (for structured search results)
#   2. Scraping Browser zone (for JS-rendered deep research)
#   3. Web Unlocker zone (for bot-detection bypass)

BRIGHT_DATA_API_KEY=your_api_key_here
BRIGHT_DATA_SERP_ZONE=your_serp_zone_name

# Scraping Browser: provide EITHER the WS endpoint OR the auth string
BRIGHT_DATA_SBR_WS_ENDPOINT=wss://brd-customer-xxx-zone-yyy@brd.superproxy.io:9222
# BRIGHT_DATA_SBR_AUTH=brd-customer-xxx-zone-yyy:password

# Web Unlocker (optional, used as fallback when Scraping Browser is unavailable)
BRIGHT_DATA_UNLOCKER_ZONE=your_unlocker_zone_name

# ── AI / LLM ──────────────────────────────────────────────────────────
VENICE_API_KEY=your_venice_api_key

# ── Prediction Markets ────────────────────────────────────────────────
POLYMARKET_PRIVATE_KEY=your_private_key

# ── Database ──────────────────────────────────────────────────────────
TURSO_CONNECTION_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_token

# ── Redis (optional, for caching) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Other Services ────────────────────────────────────────────────────
NEYNAR_API_KEY=your_neynar_key
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
NEXT_PUBLIC_WEATHER_API_KEY=your_openweather_key

# ── Autopilot Scheduler (optional) ────────────────────────────────────
# Bearer token Vercel Cron sends to /api/cron/autopilot. Unset = cron always 401s.
CRON_SECRET=your_random_cron_secret
# Gates writes to /api/agent/schedule (x-admin-secret header). Unset = writes
# denied in production, allowed only in development.
ADMIN_SECRET=your_random_admin_secret
