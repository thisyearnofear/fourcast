NEXT_PUBLIC_HOST="<your-production-url>"

# ============================================
# ⚠️ CRITICAL: DO NOT SET NODE_ENV IN THIS FILE
# ============================================
# Setting NODE_ENV manually breaks Next.js 16 builds with:
# "TypeError: Cannot read properties of null (reading 'useContext')"
# Next.js automatically sets NODE_ENV based on the command:
# - npm run dev → NODE_ENV=development
# - npm run build → NODE_ENV=production
# See: https://nextjs.org/docs/messages/non-standard-node-env
# ============================================
# Movement M1 Testnet Configuration (Bardock - Chain ID 250)
# ============================================
NEXT_PUBLIC_USE_MARKETPLACE_CONTRACT=true

# ============================================
# Polymarket Integration Environment Variables
# Copy these to .env.local and fill in your credentials

# REQUIRED: Private key for order signing on Polymarket
# WARNING: Never commit actual private keys to version control
# Export from Magic Link: https://reveal.magic.link/polymarket
# Or from MetaMask: Settings > Account > Export Private Key
POLYMARKET_PRIVATE_KEY=your_private_key_here

# OPTIONAL: Builder API credentials for gasless transactions (production)
# Only needed if using Builder Signing Server for remote signing
POLY_BUILDER_API_KEY=your_actual_api_key_here
POLY_BUILDER_SECRET=your_actual_secret_here
POLY_BUILDER_PASSPHRASE=your_actual_passphrase_here

# Polygon RPC for wallet status checks (used by /api/wallet)
# Default: https://polygon-rpc.com/ (public)
# For higher reliability, use an RPC provider like:
# - Infura: https://polygon-mainnet.infura.io/v3/{INFURA_KEY}
# - Alchemy: https://polygon-mainnet.g.alchemy.com/v2/{ALCHEMY_KEY}
NEXT_PUBLIC_BNB_RPC_URL=https://bsc-testnet.publicnode.com
NEXT_PUBLIC_BNB_CHAIN_ID=97

# Optional server signer for submitting predictions (BNB Testnet/Mainnet)
# Leave unset to require client signature via wallet
BNB_PRIVATE_KEY=

# PredictionReceipt contract address on BNBChain (required for on-chain logging)
PREDICTION_CONTRACT_ADDRESS=
PREDICTION_FEE_BPS=100

PREDICTION_CONTRACT_ADDRESS_ARBITRUM=
PREDICTION_FEE_BPS_ARBITRUM=500
ARB_RPC_URL=
ARB_PRIVATE_KEY=

PREDICTION_CONTRACT_ADDRESS_BNB=
PREDICTION_FEE_BPS_BNB=500

PREDICTION_CONTRACT_ADDRESS_POLYGON=
PREDICTION_FEE_BPS_POLYGON=100
POLYGON_RPC_URL=
POLYGON_PRIVATE_KEY=

# Redis Configuration for AI Analysis Caching (Week 1 Enhancement)
# For local development: redis://localhost:6379
# For Upstash (recommended): Use Upstash Redis REST URL
# REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Venice AI API Key for Weather Analysis

# Get from: https://venice.ai/ 

VENICE_API_KEY=your_venice_api_key_here

REDIS_URL=redis://localhost:6379



# Farcaster Integration (Neynar API)

# Get from: https://neynar.com

NEYNAR_API_KEY=your_neynar_api_key_here

# ============================================
# Circle / Arc Subscription Integration
# ============================================

# Arc RPC URL — defaults to https://arc-node.thecanteenapp.com/
ARC_RPC_URL=https://arc-node.thecanteenapp.com/

# USDC token address on Arc testnet (Circle-deployed)
NEXT_PUBLIC_USDC_TOKEN=0x3600000000000000000000000000000000000000
USDC_TOKEN_ADDRESS=0x3600000000000000000000000000000000000000

# Deployed SubscriptionManager contract address (set after deployment)
NEXT_PUBLIC_SUBSCRIPTION_CONTRACT=0xC7e26e89f85Fc91FBE80cCd85B65FdD1d8016a22

# PredictionReceiptERC20 on Arc — signal publishing (deploy: node scripts/deploy-prediction-receipt.js)
# NEXT_PUBLIC_PREDICTION_RECEIPT_CONTRACT=
# PREDICTION_FEE_BPS_ARC=0
# NEXT_PUBLIC_ARC_RPC_URL=https://arc-node.thecanteenapp.com/

# Treasury address that receives subscription USDC payments
TREASURY_ADDRESS=0x55A5705453Ee82c742274154136Fce8149597058

# Deployer private key (for deploying SubscriptionManager contract)
# DEPLOYER_PRIVATE_KEY=

# Telegram Bot (for /edge commands via messaging)
# Create bot at https://t.me/BotFather
# TELEGRAM_BOT_TOKEN=

# Photon Spectrum (for iMessage + WhatsApp multi-platform)
# Sign up at https://app.photon.codes
# PHOTON_PROJECT_ID=
# PHOTON_PROJECT_SECRET=

# Featherless AI (for Telegram bot casual queries — preferred over Venice)
# Sign up at https://featherless.ai
# FEATHERLESS_API_KEY=

# Bot API secret (shared secret for Telegram bot to authenticate with Fourcast API)
# Generate with: node -e "console.log('bot_secret_' + require('crypto').randomBytes(16).toString('hex'))"
# BOT_API_SECRET=bot_secret_

# ============================================
# Canton Network — Private Settlement Layer
# ============================================
# Fourcast uses Canton for private prediction positions with cBTC/cETH.
# Position sizes are visible only to the operator and the holder.
#
# Two connection modes:
# 1. Console Wallet (extension) — default, no config needed.
#    End-users install the Console Wallet browser extension.
#    Set NEXT_PUBLIC_CANTON_LEDGER_URL to switch to Wallet SDK mode.
# 2. Wallet SDK (direct node) — for dev/remote node access.
#    Set NEXT_PUBLIC_CANTON_LEDGER_URL to enable.
#    Get credentials from a Canton NaaS provider (see canton.foundation/validators)
#    or use the free public API at cantonnodes.com for testing.

# The Daml DAR package ID (computed at `daml build` time).
# Find it with: daml inspect .daml/dist/canton-1.0.0.dar | head -1
# Or look for the hash in canton/.daml/dist/ after building.
NEXT_PUBLIC_CANTON_DAR_PACKAGE_ID=

# The Fourcast operator's Canton party ID.
# The operator is the signatory on PredictionPosition and PredictionMarket.
# Obtain this after onboarding the operator party on the Canton node service.
CANTON_OPERATOR_PARTY_ID=

# Canton network to connect to.
# Options: localnet | devnet | mainnet
NEXT_PUBLIC_CANTON_NETWORK=localnet

# --- Wallet SDK mode (set LEDGER_URL to enable) ---
# JSON Ledger API URL from your NaaS provider or local Docker.
# Example: https://json-api.validator.your-host:7575
# Example: https://api.cantonnodes.com (free public API)
# NEXT_PUBLIC_CANTON_LEDGER_URL=

# Auth credentials (OIDC client_credentials flow)
# NEXT_PUBLIC_CANTON_AUTH_CLIENT_ID=
# CANTON_AUTH_CLIENT_SECRET=
# NEXT_PUBLIC_CANTON_AUTH_CONFIG_URL=    # OIDC .well-known/openid-configuration URL
# NEXT_PUBLIC_CANTON_AUTH_AUDIENCE=      # e.g. https://daml.com/jwt/aud/participant/{participantId}

# Canton node service URLs (for token standard / scan / registry)
# NEXT_PUBLIC_CANTON_SCAN_API_URL=
# NEXT_PUBLIC_CANTON_VALIDATOR_URL=
# NEXT_PUBLIC_CANTON_REGISTRY_URL=

# Canton participant node URL (for server-side ledger queries, optional).
# CANTON_PARTICIPANT_URL=

# Canton JSON API URL (port 7575 on the participant node, optional).
# CANTON_JSON_API_URL=
